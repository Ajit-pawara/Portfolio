# ==============================================================================
# Portfolio Environment Variables Template
# Copy this file to '.env.local' in the root directory to configure.
# DO NOT commit '.env.local' to git! It is automatically gitignored.
# ==============================================================================

# Admin Config Dashboard Password SHA-256 Hash
# Default: (hashed value of your root password)
VITE_ADMIN_PASSWORD_HASH=d4f7f87af4a1d68fc8d586d455136d1958fa4844f0abeb7ee72f7edb16d4b686

# Classified Day Content Password SHA-256 Hash
# Default: (hashed value of day lock password)
VITE_CONTENT_PASSWORD_HASH=5b8af9e5e961575968f7b58564fdd527b898ca76cf364fe1ca8b3c582753796c

# Certification Viewer Decryption Passkey SHA-256 Hash
# Default: (hashed value of certificates passkey)
VITE_CERTS_PASSWORD_HASH=c568d0c96043c60f9924afb1c1271325cee7f2fd886d59e30eb829fbdd07516d

# GitHub Personal Access Token (PAT) for direct Auto-Sync
# If set here, local development will auto-push database modifications directly to GitHub.
# (For production deployments, configure this securely in the UI settings panel instead)
VITE_GITHUB_PAT=
